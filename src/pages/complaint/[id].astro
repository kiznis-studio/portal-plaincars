---
export const prerender = false;
import Base from '../../layouts/Base.astro';
import Breadcrumb from '../../components/ui/Breadcrumb.astro';
import AdSlot from '../../components/ads/AdSlot.astro';
import { getComplaintById, getRelatedComplaints, STATE_MAP } from '../../lib/db';

const db = Astro.locals.runtime.env.DB;
const { id } = Astro.params;
const cmplid = parseInt(id || '0');
if (!cmplid) return Astro.redirect('/404');

const complaint = await getComplaintById(db, cmplid);
if (!complaint) return Astro.redirect('/404');

const related = await getRelatedComplaints(db, complaint.my_id, complaint.component, cmplid, 8);

const stateName = complaint.state && STATE_MAP[complaint.state] ? STATE_MAP[complaint.state].name : complaint.state;
const vehicleName = `${complaint.year} ${complaint.make_name} ${complaint.model_name}`;
const dateFormatted = complaint.date_added
  ? new Date(complaint.date_added.replace(/(\d{4})(\d{2})(\d{2})/, '$1-$2-$3')).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
  : 'Unknown';
const failDateFormatted = complaint.fail_date
  ? new Date(complaint.fail_date.replace(/(\d{4})(\d{2})(\d{2})/, '$1-$2-$3')).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
  : null;

const breadcrumbs = [
  { name: 'Home', href: '/' },
  { name: complaint.make_name || '', href: `/make/${complaint.my_id?.split('-')[0]}` },
  { name: `Complaint #${cmplid}` },
];

const breadcrumbSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://plaincars.com/' },
    { '@type': 'ListItem', position: 2, name: complaint.make_name, item: `https://plaincars.com/make/${complaint.my_id?.split('-')[0]}` },
    { '@type': 'ListItem', position: 3, name: `Complaint #${cmplid}` },
  ],
});
---

<Base
  title={`${vehicleName} NHTSA Complaint #${cmplid} — ${complaint.component}`}
  description={`NHTSA complaint #${cmplid} for ${vehicleName}: ${complaint.component}. ${complaint.summary?.slice(0, 120)}...`}
  breadcrumbs={breadcrumbs}
>
  <div class="max-w-4xl mx-auto px-4 py-8">
    <Breadcrumb items={breadcrumbs} />

    <h1 class="text-2xl md:text-3xl font-bold text-[var(--color-text)] mb-2 mt-4">
      {vehicleName} — Complaint #{cmplid}
    </h1>
    <p class="text-[var(--color-text-secondary)] mb-6">
      NHTSA Complaint about <strong>{complaint.component}</strong> filed {dateFormatted}
    </p>

    <!-- Key Facts -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-8">
      <div class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-lg p-4 text-center">
        <div class="text-xs text-[var(--color-text-secondary)] uppercase tracking-wider">Vehicle</div>
        <div class="text-sm font-semibold text-[var(--color-text)] mt-1">{vehicleName}</div>
      </div>
      <div class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-lg p-4 text-center">
        <div class="text-xs text-[var(--color-text-secondary)] uppercase tracking-wider">Component</div>
        <div class="text-sm font-semibold text-[var(--color-text)] mt-1">{complaint.component}</div>
      </div>
      {complaint.crash === 'Y' && (
        <div class="bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 rounded-lg p-4 text-center">
          <div class="text-xs text-amber-600 dark:text-amber-400 uppercase tracking-wider">Crash</div>
          <div class="text-sm font-semibold text-amber-600 dark:text-amber-400 mt-1">Yes</div>
        </div>
      )}
      {complaint.fire === 'Y' && (
        <div class="bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 rounded-lg p-4 text-center">
          <div class="text-xs text-amber-600 dark:text-amber-400 uppercase tracking-wider">Fire</div>
          <div class="text-sm font-semibold text-amber-600 dark:text-amber-400 mt-1">Yes</div>
        </div>
      )}
      {complaint.injured > 0 && (
        <div class="bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 rounded-lg p-4 text-center">
          <div class="text-xs text-amber-600 dark:text-amber-400 uppercase tracking-wider">Injuries</div>
          <div class="text-sm font-semibold text-amber-600 dark:text-amber-400 mt-1">{complaint.injured}</div>
        </div>
      )}
      {complaint.deaths > 0 && (
        <div class="bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 rounded-lg p-4 text-center">
          <div class="text-xs text-amber-600 dark:text-amber-400 uppercase tracking-wider">Deaths</div>
          <div class="text-sm font-semibold text-amber-600 dark:text-amber-400 mt-1">{complaint.deaths}</div>
        </div>
      )}
      {stateName && (
        <div class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-lg p-4 text-center">
          <div class="text-xs text-[var(--color-text-secondary)] uppercase tracking-wider">State</div>
          <div class="text-sm font-semibold text-[var(--color-text)] mt-1">{stateName}</div>
        </div>
      )}
      {complaint.mileage && (
        <div class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-lg p-4 text-center">
          <div class="text-xs text-[var(--color-text-secondary)] uppercase tracking-wider">Mileage</div>
          <div class="text-sm font-semibold text-[var(--color-text)] mt-1">{complaint.mileage.toLocaleString()} mi</div>
        </div>
      )}
    </div>

    <AdSlot slot="top" />

    <!-- Complaint Description -->
    <div class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-lg p-6 mb-8">
      <h2 class="text-lg font-semibold text-[var(--color-text)] mb-3">Complaint Description</h2>
      <p class="text-[var(--color-text)] leading-relaxed whitespace-pre-line">{complaint.summary}</p>
    </div>

    <!-- Details Table -->
    <div class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-lg overflow-hidden mb-8">
      <h2 class="text-lg font-semibold text-[var(--color-text)] px-6 py-4 border-b border-[var(--color-border)]">Complaint Details</h2>
      <table class="w-full text-sm">
        <tbody>
          <tr class="border-b border-[var(--color-border)]">
            <td class="px-6 py-3 text-[var(--color-text-secondary)] font-medium w-1/3">NHTSA Complaint ID</td>
            <td class="px-6 py-3 text-[var(--color-text)]">{cmplid}</td>
          </tr>
          <tr class="border-b border-[var(--color-border)]">
            <td class="px-6 py-3 text-[var(--color-text-secondary)] font-medium">ODI Number</td>
            <td class="px-6 py-3 text-[var(--color-text)]">{complaint.odi_number}</td>
          </tr>
          <tr class="border-b border-[var(--color-border)]">
            <td class="px-6 py-3 text-[var(--color-text-secondary)] font-medium">Date Filed</td>
            <td class="px-6 py-3 text-[var(--color-text)]">{dateFormatted}</td>
          </tr>
          {failDateFormatted && (
            <tr class="border-b border-[var(--color-border)]">
              <td class="px-6 py-3 text-[var(--color-text-secondary)] font-medium">Failure Date</td>
              <td class="px-6 py-3 text-[var(--color-text)]">{failDateFormatted}</td>
            </tr>
          )}
          {complaint.vin && (
            <tr class="border-b border-[var(--color-border)]">
              <td class="px-6 py-3 text-[var(--color-text-secondary)] font-medium">VIN</td>
              <td class="px-6 py-3 text-[var(--color-text)]">
                <a href={`/vin/${complaint.vin}`} class="text-[var(--color-primary)] hover:underline">{complaint.vin}</a>
              </td>
            </tr>
          )}
        </tbody>
      </table>
    </div>

    <AdSlot slot="mid" />

    <!-- Related Complaints -->
    {related.length > 0 && (
      <div class="mb-8">
        <h2 class="text-xl font-semibold text-[var(--color-text)] mb-4">
          Similar {complaint.component} Complaints for {vehicleName}
        </h2>
        <div class="space-y-3">
          {related.map(r => (
            <a href={`/complaint/${r.cmplid}`} class="block bg-[var(--color-surface)] border border-[var(--color-border)] rounded-lg p-4 hover:border-[var(--color-primary)] transition-colors">
              <div class="flex justify-between items-start mb-1">
                <span class="text-sm font-medium text-[var(--color-text)]">Complaint #{r.cmplid}</span>
                <div class="flex gap-2">
                  {r.crash === 'Y' && <span class="text-xs px-2 py-0.5 rounded bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-400">Crash</span>}
                  {r.fire === 'Y' && <span class="text-xs px-2 py-0.5 rounded bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-400">Fire</span>}
                </div>
              </div>
              <p class="text-sm text-[var(--color-text-secondary)] line-clamp-2">{r.summary?.slice(0, 200)}</p>
            </a>
          ))}
        </div>
      </div>
    )}

    <AdSlot slot="bottom" />

    <!-- Links -->
    <div class="mt-8 text-sm text-[var(--color-text-secondary)]">
      <p>Source: <a href="https://www.nhtsa.gov/recalls-complaints/complaints" class="text-[var(--color-primary)] hover:underline" target="_blank" rel="noopener">NHTSA Vehicle Complaints Database</a></p>
    </div>
  </div>
  <script type="application/ld+json" set:html={breadcrumbSchema} />
</Base>
