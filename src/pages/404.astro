---
export const prerender = true;
import Base from '../layouts/Base.astro';
---

<Base title="Page Not Found" description="The page you're looking for doesn't exist.">
  <div class="max-w-6xl mx-auto px-4 py-24 text-center">
    <h1 class="text-6xl font-bold text-[var(--color-primary)] mb-4">404</h1>
    <p class="text-xl text-[var(--color-text)] mb-2">Page not found</p>
    <p class="text-[var(--color-text-secondary)] mb-8">The vehicle or page you're looking for doesn't exist.</p>
    <div class="flex items-center justify-center gap-4">
      <a href="/" class="px-6 py-3 bg-[var(--color-primary)] text-white rounded-lg hover:opacity-90 transition-opacity font-medium">Go Home</a>
      <a href="/search" class="px-6 py-3 border border-[var(--color-border)] rounded-lg hover:bg-[var(--color-surface)] transition-colors text-[var(--color-text)]">Search</a>
    </div>
  </div>
</Base>
