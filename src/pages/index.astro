---
export const prerender = false;
import Base from '../layouts/Base.astro';
import { getAllMakes, getNationalStats, getMostComplainedModels } from '../lib/db';

const db = Astro.locals.runtime.env.DB;
const [makes, stats, topModels] = await Promise.all([
  getAllMakes(db),
  getNationalStats(db),
  getMostComplainedModels(db, 10),
]);

const popularMakes = makes.filter(m => m.complaint_count > 5000).slice(0, 20);

const datasetSchema = {
  "@context": "https://schema.org",
  "@type": "Dataset",
  "name": "U.S. Vehicle Safety Ratings, Complaints, and Recalls",
  "description": "NHTSA data covering 70 makes, 3,500+ models, 454,000+ consumer complaints, 37,500+ recalls, and 3,500+ safety ratings.",
  "url": "https://plaincars.com",
  "keywords": ["car safety ratings", "NHTSA", "vehicle recalls", "car complaints", "US auto safety"],
  "creator": {
    "@type": "Organization",
    "name": "PlainCars"
  },
  "spatialCoverage": "United States",
  "temporalCoverage": "2000/2025",
  "license": "https://creativecommons.org/publicdomain/zero/1.0/",
  "isAccessibleForFree": true,
  "distribution": {
    "@type": "DataDownload",
    "encodingFormat": "text/html",
    "contentUrl": "https://plaincars.com"
  }
};
---

<Base
  title="PlainCars — Vehicle Safety, Complaints & Recalls from NHTSA"
  description="Search NHTSA vehicle complaints, recalls, and safety ratings. Free data on every car, truck, and SUV sold in America."
>
  <!-- Hero -->
  <section class="bg-gradient-to-b from-[var(--color-surface)] to-[var(--color-bg)] py-16 md:py-24">
    <div class="max-w-6xl mx-auto px-4 text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-[var(--color-text)] mb-4">
        Vehicle Safety Data,<br/><span class="text-[var(--color-primary)]">Made Simple</span>
      </h1>
      <p class="text-lg text-[var(--color-text-secondary)] max-w-2xl mx-auto mb-8">
        Search {stats?.total_complaints?.toLocaleString()} NHTSA complaints and {stats?.total_recalls?.toLocaleString()} recalls
        across {stats?.total_models?.toLocaleString()} vehicle models. Free, open data from the National Highway Traffic Safety Administration.
      </p>
      <form action="/search" method="get" class="max-w-md mx-auto">
        <div class="relative">
          <input type="text" name="q" placeholder="Search by make, model, or year..." class="w-full h-12 pl-12 pr-4 text-base rounded-xl border border-[var(--color-border)] bg-[var(--color-bg)] text-[var(--color-text)] placeholder-[var(--color-text-secondary)] focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)] focus:border-transparent shadow-sm" />
          <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-[var(--color-text-secondary)]" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
        </div>
      </form>
    </div>
  </section>

  <!-- Stats -->
  <section class="py-12">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <div class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-lg p-5 text-center">
          <div class="text-2xl font-bold text-[var(--color-primary)]">{stats?.total_complaints?.toLocaleString()}</div>
          <div class="text-xs text-[var(--color-text-secondary)] mt-1">Complaints</div>
        </div>
        <div class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-lg p-5 text-center">
          <div class="text-2xl font-bold text-[var(--color-primary)]">{stats?.total_recalls?.toLocaleString()}</div>
          <div class="text-xs text-[var(--color-text-secondary)] mt-1">Recalls</div>
        </div>
        <div class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-lg p-5 text-center">
          <div class="text-2xl font-bold text-[var(--color-primary)]">{stats?.total_models?.toLocaleString()}</div>
          <div class="text-xs text-[var(--color-text-secondary)] mt-1">Vehicle Models</div>
        </div>
        <div class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-lg p-5 text-center">
          <div class="text-2xl font-bold text-[var(--color-primary)]">{stats?.total_makes?.toLocaleString()}</div>
          <div class="text-xs text-[var(--color-text-secondary)] mt-1">Makes</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Most Complained Models -->
  <section class="py-8">
    <div class="max-w-6xl mx-auto px-4">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-xl font-bold text-[var(--color-text)]">Most Complained Vehicle Models</h2>
        <a href="/rankings" class="text-sm text-[var(--color-primary)] hover:underline">View all rankings &rarr;</a>
      </div>
      <div class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-lg overflow-hidden">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-[var(--color-border)] bg-[var(--color-surface-alt)]">
              <th class="text-left px-4 py-3 font-medium">#</th>
              <th class="text-left px-4 py-3 font-medium">Vehicle</th>
              <th class="text-right px-4 py-3 font-medium">Complaints</th>
              <th class="text-right px-4 py-3 font-medium hidden sm:table-cell">Years</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-[var(--color-border)]">
            {topModels.map((m: any, i: number) => (
              <tr class="hover:bg-[var(--color-surface-alt)] transition-colors">
                <td class="px-4 py-3 text-[var(--color-text-secondary)]">{i + 1}</td>
                <td class="px-4 py-3">
                  <a href={`/make/${m.slug}`} class="font-medium text-[var(--color-primary)] hover:underline">
                    {m.make_name} {m.model_name}
                  </a>
                </td>
                <td class="text-right px-4 py-3 text-[var(--color-text-secondary)]">{m.complaint_count?.toLocaleString()}</td>
                <td class="text-right px-4 py-3 text-[var(--color-text-secondary)] hidden sm:table-cell">{m.year_min}–{m.year_max}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Guides Section -->
  <section class="py-12 md:py-16 bg-[var(--color-surface)] border-t border-[var(--color-border)]">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-[var(--color-text)] mb-3">Learn &amp; Explore</h2>
      <p class="text-[var(--color-text-secondary)] mb-8 max-w-2xl">
        Go beyond the data with our in-depth guides on vehicle safety, recalls, and how to make smarter car-buying decisions.
      </p>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        <a href="/guides/understanding-nhtsa-complaints" class="block p-5 bg-[var(--color-bg)] border border-[var(--color-border)] rounded-lg hover:border-[var(--color-primary)] transition-colors">
          <h3 class="font-semibold text-[var(--color-text)] mb-2">Understanding NHTSA Complaints</h3>
          <p class="text-sm text-[var(--color-text-secondary)]">How consumer vehicle complaints get filed, what they mean, and how to use them when buying a used car.</p>
        </a>
        <a href="/guides/vehicle-recalls-explained" class="block p-5 bg-[var(--color-bg)] border border-[var(--color-border)] rounded-lg hover:border-[var(--color-primary)] transition-colors">
          <h3 class="font-semibold text-[var(--color-text)] mb-2">Vehicle Recalls Explained</h3>
          <p class="text-sm text-[var(--color-text-secondary)]">What triggers a vehicle recall, how to check if your car is affected, and what to do next.</p>
        </a>
        <a href="/guides/safest-car-brands-2026" class="block p-5 bg-[var(--color-bg)] border border-[var(--color-border)] rounded-lg hover:border-[var(--color-primary)] transition-colors">
          <h3 class="font-semibold text-[var(--color-text)] mb-2">Safest Car Brands in 2026</h3>
          <p class="text-sm text-[var(--color-text-secondary)]">Which automakers have the fewest complaints and recalls per vehicle? A data-driven look at brand safety records.</p>
        </a>
      </div>
      <div class="mt-6 text-center">
        <a href="/guides/" class="text-[var(--color-primary)] hover:underline font-medium">View all guides &rarr;</a>
      </div>
    </div>
  </section>

  <!-- Popular Makes -->
  <section class="py-8 pb-16">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="text-xl font-bold text-[var(--color-text)] mb-6">Browse by Make</h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3">
        {popularMakes.map(m => (
          <a href={`/make/${m.slug}`} class="flex items-center justify-between px-4 py-3 bg-[var(--color-surface)] border border-[var(--color-border)] rounded-lg hover:border-[var(--color-primary)] hover:shadow-sm transition-all">
            <span class="font-medium text-sm text-[var(--color-text)]">{m.make_name}</span>
            <span class="text-xs text-[var(--color-text-secondary)]">{m.model_count}</span>
          </a>
        ))}
      </div>
      <div class="text-center mt-6">
        <a href="/make" class="text-sm text-[var(--color-primary)] hover:underline">View all {makes.length} makes &rarr;</a>
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(datasetSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'PlainCars',
    url: 'https://plaincars.com/',
    potentialAction: {
      '@type': 'SearchAction',
      target: { '@type': 'EntryPoint', urlTemplate: 'https://plaincars.com/search?q={search_term_string}' },
      'query-input': 'required name=search_term_string',
    },
  })} />
</Base>
