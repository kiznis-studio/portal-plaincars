---
export const prerender = false;
import Base from '../../layouts/Base.astro';
import Breadcrumb from '../../components/ui/Breadcrumb.astro';
import AdSlot from '../../components/ads/AdSlot.astro';
import { getAllComponents } from '../../lib/db';

const db = Astro.locals.runtime.env.DB;
const components = await getAllComponents(db);

const totalComplaints = components.reduce((sum, c) => sum + c.complaint_count, 0);

const breadcrumbs = [
  { name: 'Home', href: '/' },
  { name: 'Components' },
];

const breadcrumbSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://plaincars.com/' },
    { '@type': 'ListItem', position: 2, name: 'Components' },
  ],
});
---

<Base
  title="Vehicle Component Safety Complaints — NHTSA Data by Part Category"
  description={`Browse ${components.length} vehicle component categories with ${totalComplaints.toLocaleString()} NHTSA safety complaints. Find the most problematic vehicle parts, from airbags to transmissions.`}
  breadcrumbs={breadcrumbs}
>
  <div class="max-w-6xl mx-auto px-4 py-8">
    <Breadcrumb items={breadcrumbs} />

    <h1 class="text-3xl font-bold text-[var(--color-text)] mb-2 mt-4">Vehicle Component Safety Data</h1>
    <p class="text-[var(--color-text-secondary)] mb-8 leading-relaxed">
      Browse <strong>{components.length}</strong> vehicle component categories with <strong>{totalComplaints.toLocaleString()} NHTSA safety complaints</strong>. Click any component to see which vehicles are most affected.
    </p>

    <AdSlot slot="top" />

    <!-- Top Components Grid -->
    <div class="grid gap-3 md:grid-cols-2 lg:grid-cols-3 mb-8">
      {components.slice(0, 30).map(c => (
        <a href={`/component/${c.component_slug}`} class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-lg p-4 hover:border-[var(--color-primary)] transition-colors">
          <h3 class="font-semibold text-[var(--color-text)] text-sm mb-2 line-clamp-1">{c.component}</h3>
          <div class="flex flex-wrap gap-x-4 gap-y-1 text-xs text-[var(--color-text-secondary)]">
            <span>{c.complaint_count.toLocaleString()} complaints</span>
            <span>{c.affected_models.toLocaleString()} models</span>
            {c.crash_count > 0 && <span class="text-amber-600 dark:text-amber-400">{c.crash_count.toLocaleString()} crashes</span>}
            {c.death_count > 0 && <span class="text-amber-600 dark:text-amber-400">{c.death_count.toLocaleString()} deaths</span>}
          </div>
        </a>
      ))}
    </div>

    <AdSlot slot="mid" />

    <!-- Full List Table -->
    {components.length > 30 && (
      <div class="bg-[var(--color-surface)] border border-[var(--color-border)] rounded-lg overflow-hidden mb-8">
        <h2 class="text-lg font-semibold text-[var(--color-text)] px-6 py-4 border-b border-[var(--color-border)]">All Components</h2>
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-[var(--color-border)] bg-[var(--color-bg)]">
                <th class="px-4 py-3 text-left text-[var(--color-text-secondary)] font-medium">Component</th>
                <th class="px-4 py-3 text-right text-[var(--color-text-secondary)] font-medium">Complaints</th>
                <th class="px-4 py-3 text-right text-[var(--color-text-secondary)] font-medium hidden md:table-cell">Models</th>
                <th class="px-4 py-3 text-right text-[var(--color-text-secondary)] font-medium hidden md:table-cell">Crashes</th>
                <th class="px-4 py-3 text-right text-[var(--color-text-secondary)] font-medium hidden md:table-cell">Deaths</th>
              </tr>
            </thead>
            <tbody>
              {components.slice(30).map((c, i) => (
                <tr class="border-b border-[var(--color-border)]">
                  <td class="px-4 py-2.5">
                    <a href={`/component/${c.component_slug}`} class="text-[var(--color-primary)] hover:underline text-sm">{c.component}</a>
                  </td>
                  <td class="px-4 py-2.5 text-right text-[var(--color-text)]">{c.complaint_count.toLocaleString()}</td>
                  <td class="px-4 py-2.5 text-right text-[var(--color-text-secondary)] hidden md:table-cell">{c.affected_models}</td>
                  <td class="px-4 py-2.5 text-right text-[var(--color-text-secondary)] hidden md:table-cell">{c.crash_count.toLocaleString()}</td>
                  <td class="px-4 py-2.5 text-right text-[var(--color-text-secondary)] hidden md:table-cell">{c.death_count.toLocaleString()}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    )}

    <AdSlot slot="bottom" />

    <div class="mt-8 text-sm text-[var(--color-text-secondary)]">
      <p>Source: <a href="https://www.nhtsa.gov/recalls-complaints/complaints" class="text-[var(--color-primary)] hover:underline" target="_blank" rel="noopener">NHTSA Vehicle Complaints Database</a></p>
    </div>
  </div>
  <script type="application/ld+json" set:html={breadcrumbSchema} />
</Base>
